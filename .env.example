# Path to the SQLite database file (better-sqlite3).
DATABASE_URL=local.db

# Auth.js secret — used to sign session JWTs. Required in production; generate
# with `openssl rand -base64 33` (or `npx auth secret`).
AUTH_SECRET=dev-secret-change-me

# Sign-in providers. Dev-login (zero-config, no OAuth) is on by default; set to
# false in production once a real provider is configured.
AUTH_DEV_LOGIN=true

# Optional OAuth providers — each switches on when both id and secret are set.
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_DISCORD_ID=
# AUTH_DISCORD_SECRET=
