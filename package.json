{
	"name": "splatbook",
	"private": true,
	"version": "2.1.0",
	"license": "GPL-3.0-or-later",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "(svelte-kit sync && git config core.hooksPath .githooks) || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"validate:packs": "tsx tools/validate-packs.ts",
		"build:search": "tsx tools/build_search.ts",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"@auth/drizzle-adapter": "^1.11.2",
		"@auth/sveltekit": "^1.11.2",
		"@fontsource/eb-garamond": "^5.2.7",
		"better-sqlite3": "^12.11.1",
		"drizzle-orm": "^0.45.2",
		"marked": "^14.1.4",
		"minisearch": "^7.2.0"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^5.20260711.1",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.2",
		"@types/better-sqlite3": "^7.6.13",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^16.0.0",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.2",
		"tsx": "^4.23.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.63.0",
		"vite": "^8.0.16",
		"vitest": "^4.0.0",
		"wrangler": "^4.110.0",
		"zod": "^4.4.3"
	}
}
